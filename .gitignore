# ==============================================================================
# .gitignore — MrPress LLC
# https://github.com/HP6673
# © 2025 MrPress LLC. All Rights Reserved.
# ==============================================================================
# This file instructs Git to ignore files and directories that should not
# be tracked or committed to this repository. This includes operating system
# artifacts, editor configuration files, temporary files, and any sensitive
# local configuration that should never be made public.
# ==============================================================================


# ------------------------------------------------------------------------------
# Operating System Files
# ------------------------------------------------------------------------------

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon?

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*


# ------------------------------------------------------------------------------
# Editor and IDE Files
# ------------------------------------------------------------------------------

# Visual Studio Code
.vscode/
*.code-workspace
.history/

# JetBrains IDEs (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist
Session.vim
.vim/

# Emacs
*#
.#*
\#*#
*.elc
auto-save-list
tramp
.\#*

# Atom
.atom/

# Brackets
.brackets.json


# ------------------------------------------------------------------------------
# Sensitive and Local Configuration
# ------------------------------------------------------------------------------

# Environment variable files — NEVER commit secrets or keys
.env
.env.*
.env.local
.env.development
.env.production
.env.staging
.env.test
*.env

# Local configuration overrides
config.local.*
local.config.*
local.settings.*

# API keys, tokens, credentials — should never be in version control
secrets/
credentials/
*.key
*.pem
*.p12
*.pfx
*.cert
*.crt
*.cer


# ------------------------------------------------------------------------------
# Node.js (if any tooling is ever added)
# ------------------------------------------------------------------------------

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn/
.pnp.*
package-lock.json
yarn.lock
pnpm-lock.yaml


# ------------------------------------------------------------------------------
# Build Output and Temporary Files
# ------------------------------------------------------------------------------

dist/
build/
out/
.cache/
.temp/
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
*.orig
*.log
*.logs


# ------------------------------------------------------------------------------
# Miscellaneous
# ------------------------------------------------------------------------------

# Archive files — don't commit compressed project archives
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# Thumbnail caches
.thumbnails/

# Local development notes (keep these off GitHub)
TODO.local.md
NOTES.local.md
SCRATCH.md
scratch/
